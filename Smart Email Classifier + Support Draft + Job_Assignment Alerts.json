    {
      "parameters": {
        "jsCode": "const raw = $json.text || $json.output || $json.response || JSON.stringify($json);\nlet parsed;\n\ntry {\n  parsed = typeof raw === 'string' ? JSON.parse(raw) : raw;\n} catch (e) {\n  parsed = {\n    category: 'Spam',\n    priority: 'low',\n    reason: 'Failed to parse classifier output'\n  };\n}\n\nreturn [{\n  json: {\n    ...$input.first().json,\n    category: parsed.category || 'Spam',\n    priority: parsed.priority || 'low',\n    reason: parsed.reason || 'No reason provided'\n  }\n}];"
      },
