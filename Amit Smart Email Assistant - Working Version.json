    {
      "parameters": {
        "content": "## 🤖 Rule-Based Classifier (Most Stable)\nThis section classifies emails without relying on fragile LLM JSON parsing.\n\nCategories:\n- Promotional\n- Support\n- Order_Query\n- Job_Opportunity\n- Assignment\n- Spam",
        "height": 340,
        "width": 400,
        "color": 4
      },
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        32,
        1152
      ],
      "id": "274ac03c-b129-414d-b543-4abe3a13b569",
      "name": "Sticky Note - Classifier"
    },
    {
      "parameters": {
        "jsCode": "const subject = ($json.subjectLine || '').toLowerCase();\nconst body = ($json.snippetText || '').toLowerCase();\nconst from = ($json.senderEmail || '').toLowerCase();\nconst text = `${subject} ${body} ${from}`;\n\nlet category = 'Promotional';\nlet priority = 'low';\nlet reason = 'General promotional or low-priority email';\n\nconst hasAny = (arr) => arr.some(k => text.includes(k));\n\nif (hasAny(['internship','job opening','hiring','recruiter','opportunity','interview','career','application shortlisted','we are hiring','role'])) {\n  category = 'Job_Opportunity';\n  priority = 'high';\n  reason = 'Job or internship related email';\n} else if (hasAny(['assignment','submission','deadline','quiz','test','lab','project submission','coursework','classwork','exam'])) {\n  category = 'Assignment';\n  priority = 'high';\n  reason = 'Academic task or deadline email';\n} else if (hasAny(['order','shipment','tracking','invoice','refund','replacement','delivery','dispatch','payment received','return request'])) {\n  category = 'Order_Query';\n  priority = 'high';\n  reason = 'Order or delivery related email';\n} else if (hasAny(['support','issue','problem','unable','error','help','not working','complaint','customer service','login issue'])) {\n  category = 'Support';\n  priority = 'medium';\n  reason = 'Support or issue related email';\n} else if (hasAny(['unsubscribe','offer','discount','sale','webinar','newsletter','promo','campaign','register now','limited time'])) {\n  category = 'Promotional';\n  priority = 'low';\n  reason = 'Promotional or marketing email';\n} else if (hasAny(['lottery','urgent response','click here now','winner','claim prize','verify immediately','bank update'])) {\n  category = 'Spam';\n  priority = 'low';\n  reason = 'Likely spam or suspicious email';\n}\n\nreturn [{ json: { ...$json, category, priority, reason } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        272,
        1296
      ],
      "id": "361f6e9a-bd42-4475-a8eb-0537782f3d5c",
      "name": "Classify_Email_Safely"
